DATABASE_URL=postgres://postgres:postgres@localhost:5432/bookroom_db?sslmode=disable
PORT=8080

# PostgreSQL container vars — required by the postgres Docker image to initialise
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bookroom_db

# ── Application environment ───────────────────────────────────────────────────
# Set to "production" to enable: Secure cookies, HTTPS redirect, HSTS header,
# and the __Host- cookie prefix. Leave blank for local development.
APP_ENV=production

# Public base URL of this app — used to build the password-reset link in emails.
# Example: https://smartbook.company.bt
# Leave as http://localhost:8080 for local development.
APP_URL=https://smartbook-yefc.onrender.com

# ── Resend — email API for password-reset emails ─────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month, 100/day.
# If RESEND_API_KEY is blank the reset link is shown on-screen (dev mode only).

# API key from the Resend dashboard  (Settings → API Keys → Create API Key)
RESEND_API_KEY=re_EBQG9Pqu_3bXpiXSCyf5BsAbfSG6wagoo

# "From" address shown to the recipient.
# Must be a verified domain in Resend.
# While testing you can use the shared Resend domain:  SmartBook <onboarding@resend.dev>
# For production use your own domain:                  SmartBook <no-reply@yourdomain.com>
EMAIL_FROM=smart_no_reply@dhi.bt