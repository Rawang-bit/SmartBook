DATABASE_URL=postgres://postgres:postgres@localhost:5432/bookroom_db?sslmode=disable
PORT=8080

# PostgreSQL container vars — required by the postgres Docker image to initialise
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=bookroom_db

# ── Application environment ───────────────────────────────────────────────────
# Set to "production" to enable: Secure cookies, HTTPS redirect, HSTS header,
# and the __Host- cookie prefix. Leave blank for local development.
APP_ENV=

# Public base URL of this app — used to build the password-reset link in emails.
# Example: https://smartbook.company.bt
# Leave as http://localhost:8080 for local development.
APP_URL=

# ── SMTP — email delivery for password-reset emails ──────────────────────────
# If SMTP_HOST is left blank the reset link is shown on-screen (dev mode only).

# Mail server hostname  e.g. smtp.gmail.com
SMTP_HOST=

# Mail server port  587 = STARTTLS (recommended)  465 = implicit TLS
SMTP_PORT=587

# Login credentials for the SMTP account
SMTP_USERNAME=
SMTP_PASSWORD=

# The "From" address shown in the email
# If blank, falls back to SMTP_USERNAME
SMTP_FROM=